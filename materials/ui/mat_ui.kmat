material ui_default 
{
	fullbright
	blend
	depthtest
	nodepthmask
    cull back
    param "uLimitAlpha" 0 "0"
    param "uReflective" 0 "0"
    param "uPseduoColor" 0 "0"
    sort translucent
    surface_type default
    color_diffuse "0.800000 0.800000 0.800000 1.000000"
    sampler "diffuse" 0 "textures/ui/white.png" 
	{
        filter      nearest
        wrap        clamp
    }
}