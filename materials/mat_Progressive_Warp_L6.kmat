// model 0569, section 00
material surf_569_00_00 {
    fullbright
    cull back
    param "uLimitAlpha" 0 "0"
    param "uReflective" 0 "0"
    param "uPseduoColor" 0 "0"
    sort default
    surface_type default
    depthtest
    color_environment "0.000000 0.000000 0.000000 1.000000"
    color_diffuse "1.000000 1.000000 1.000000 1.000000"
    sampler "diffuse" 0 "textures/hubkey03.png" {
        filter      linear_anisotropic
        wrap        repeat
    }
}

